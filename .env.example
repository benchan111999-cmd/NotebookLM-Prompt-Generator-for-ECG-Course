# Copy this file to .env.local for local development.
# Do not commit real secrets.

# Required for backend Gemini API calls.
# Keep this key server-side only. Never expose it with a VITE_ prefix.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional override for local frontend proxy target.
VITE_BACKEND_URL="http://localhost:8787"

# URL where this app is hosted.
# AI Studio can inject this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
